generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id         String   @id @default(cuid())

  email      String
  reference  String   @unique
  amount     Int
  status     String

  accessKey  String   @unique

  expiresAt  DateTime

  createdAt  DateTime @default(now())
}